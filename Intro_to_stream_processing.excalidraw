    {
      "id": "tLtvXs6psUrpdOI7XwFha",
      "type": "text",
      "x": 463.30328251475987,
      "y": 1204,
      "width": 887.6994018554688,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aD",
      "roundness": null,
      "seed": 386885258,
      "version": 120,
      "versionNonce": 832772670,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779331150373,
      "link": null,
      "locked": false,
      "text": "Event time\n     The time when the event was created. \n     The time information is provided by the local clock of the device generating the event.\n\nProcessing time\n     The time when the event is handled by the stream-processing system. \n     This is the clock of the server running the processing logic. \n     It’s usually relevant for technical reasons like computing the processing lag \n           or as criteria to determine duplicated output.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Event time\n     The time when the event was created. \n     The time information is provided by the local clock of the device generating the event.\n\nProcessing time\n     The time when the event is handled by the stream-processing system. \n     This is the clock of the server running the processing logic. \n     It’s usually relevant for technical reasons like computing the processing lag \n           or as criteria to determine duplicated output.",
      "autoResize": true,
      "lineHeight": 1.25
    },
