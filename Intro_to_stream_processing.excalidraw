      "isDeleted": false,
      "boundElements": [],
      "updated": 1779309092111,
      "link": null,
      "locked": false,
      "text": "Similar to Dataframe and Datasets for Spark Streaming we have a abstraction called \nDiscretized Stream or DStream",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Similar to Dataframe and Datasets for Spark Streaming we have a abstraction called \nDiscretized Stream or DStream",
      "autoResize": true,
      "lineHeight": 1.25
    },
