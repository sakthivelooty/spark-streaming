      "isDeleted": false,
      "boundElements": [],
      "updated": 1779309089709,
      "link": null,
      "locked": false,
      "text": "apply Spark’s distributed computing capabilities to stream processing \nby transforming continuous streams of data into discrete data collections \non which Spark could operate.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "apply Spark’s distributed computing capabilities to stream processing \nby transforming continuous streams of data into discrete data collections \non which Spark could operate.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "BjkyQpY3R3gbew3mEUXm5",
      "type": "text",
      "x": 354,
