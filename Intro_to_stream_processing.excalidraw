      "seed": 62634826,
      "version": 33,
      "versionNonce": 1743517590,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779309168826,
      "link": null,
      "locked": false,
      "text": "Structured Streaming is a stream processor built on top of the Spark SQL abstraction\nIt extends the Dataset and DataFrame APIs with streaming capabilities,  \nand inherits all the optimizations implemented in Spark SQL.\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Structured Streaming is a stream processor built on top of the Spark SQL abstraction\nIt extends the Dataset and DataFrame APIs with streaming capabilities,  \nand inherits all the optimizations implemented in Spark SQL.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
