      "updated": 1779309085103,
      "link": null,
      "locked": false,
      "text": "History:\nSpark Streaming was the first stream-processing framework built on top\nof the core Spark engine. It was introduced in the Spark 0.7.0 release in February of 2013\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "History:\nSpark Streaming was the first stream-processing framework built on top\nof the core Spark engine. It was introduced in the Spark 0.7.0 release in February of 2013\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
