      "locked": false,
      "text": "They expand dynamically as long as events arrive closely together and only \nclose when there is a period of silence (the timeout or gap duration).",
      "fontSize": 19.2,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "They expand dynamically as long as events arrive closely together and only \nclose when there is a period of silence (the timeout or gap duration).",
      "autoResize": true,
      "lineHeight": 1.25
    },
